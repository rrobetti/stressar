---
# ansible/templates/pgbouncer-benchmark.yaml.j2
#
# Jinja2 template for a PgBouncer benchmark run (SUT-C).
# Rendered by run_benchmarks_pgbouncer.yml into /tmp/pgbouncer-benchmark-{{ run_name }}.yaml
# before each bench invocation.

database:
  # prepareThreshold=0: disables PostgreSQL server-side prepared statements.
  # Required for pgBouncer transaction pooling mode: each transaction may be
  # routed to a different backend, so session-scoped prepared statements would
  # cause "prepared statement does not exist" errors and xact_rollback spikes.
  jdbcUrl: "jdbc:postgresql://{{ lb_host }}:{{ pgbouncer_port }}/{{ db_name }}?prepareThreshold=0"
  username: "{{ db_user }}"
  password: "{{ db_password }}"

connectionMode: PGBOUNCER

# Configurable local client-side pool.
# - benchmark/fair-comparison profile can use a small value (see docs/PARAMETER_DECISIONS.md §28)
# - production profile can override with a larger value in ansible/vars/prod-pgbouncer.yml
poolSize: {{ pgbouncer_local_pool_size }}
replicas: {{ bench_replica_count }}

workload:
  type: {{ bench_workload_type }}
  openLoop: true
  targetRps: {{ bench_target_rps }}
  warmupSeconds: {{ bench_warmup_seconds }}
  durationSeconds: {{ bench_duration_seconds }}
  cooldownSeconds: {{ bench_cooldown_seconds }}

numAccounts: {{ bench_num_accounts }}
numItems:    {{ bench_num_items }}
numOrders:   {{ bench_num_orders }}

metricsIntervalSeconds: 1
outputDir: "{{ bench_results_dir }}/{{ run_name }}"

sweepIncrementPercent: 15.0
sloP95Ms: {{ bench_slo_p95_ms | default(50) }}
errorRateThreshold: 0.001
