---
# ansible/templates/ojp-benchmark.yaml.j2
#
# Jinja2 template for an OJP production-topology benchmark run (SUT-B).
# Rendered by run_benchmarks_ojp.yml into /tmp/ojp-benchmark-{{ run_name }}.yaml
# before each bench invocation.

database:
  jdbcUrl: "jdbc:ojp[{{ proxy_urls | join(',') }}]_postgresql://{{ db_host }}:{{ db_port }}/{{ db_name }}"
  username: "{{ db_user }}"
  password: "{{ db_password }}"

connectionMode: {{ bench_connection_mode }}
# OJP clients do not use a local HikariCP pool. JDBC connections are logical on
# the client side; real PostgreSQL backend connections are pooled in OJP servers.
dbConnectionBudget: {{ bench_db_connection_budget }}
replicas: {{ bench_replica_count }}

ojp:
  virtualConnectionMode: PER_WORKER
  poolSharing: PER_INSTANCE
  # The OJP cluster is self-aware: every OJP server receives the full
  # bench_db_connection_budget as maxConnections and the cluster automatically
  # divides that budget across its nodes (e.g. budget=48, 3 servers → 16 each).
  # The Java client never divides the budget; bench_replica_count (load-gen JVMs)
  # is irrelevant to OJP pool sizing.
  # minConnections = maxConnections so each node's share is fully pre-warmed.
  minConnections: {{ bench_db_connection_budget | int }}
  connectionTimeoutMs: 30000
  idleTimeoutMs: 600000
  maxLifetimeMs: 1800000
  queueLimit: 200
  slowQueryThresholdMs: 1000

workload:
  type: {{ bench_workload_type }}
  openLoop: true
  targetRps: {{ bench_target_rps }}
  warmupSeconds: {{ bench_warmup_seconds }}
  durationSeconds: {{ bench_duration_seconds }}
  cooldownSeconds: {{ bench_cooldown_seconds }}

numAccounts: {{ bench_num_accounts }}
numItems:    {{ bench_num_items }}
numOrders:   {{ bench_num_orders }}

metricsIntervalSeconds: 1
outputDir: "{{ bench_results_dir }}/{{ run_name }}"

sweepIncrementPercent: 15.0
sloP95Ms: {{ bench_slo_p95_ms | default(50) }}
errorRateThreshold: 0.001
