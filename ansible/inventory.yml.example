---
# ansible/inventory.yml.example
#
# Copy this file to inventory.yml, fill in your actual IP addresses or hostnames,
# and optionally set per-host SSH user overrides.
#
# Usage:
#   cp ansible/inventory.yml.example ansible/inventory.yml
#   # edit ansible/inventory.yml
#   ansible-playbook -i ansible/inventory.yml ansible/playbooks/setup.yml

all:
  vars:
    # SSH user for all remote machines.
    # Override per host below if machines use different users.
    ansible_user: ubuntu

  children:

    # ─────────────────────────────────────────────────────────────
    # Database server — one host only
    # ─────────────────────────────────────────────────────────────
    db:
      hosts:
        db-node:
          ansible_host: <DB_IP>
          # ansible_user: ec2-user   # uncomment to override per host

    # ─────────────────────────────────────────────────────────────
    # Proxy nodes — three hosts (shared by BOTH scenarios)
    #
    # SUT-B (OJP):       OJP Server is installed and runs here.
    # SUT-C (pgBouncer): pgBouncer is installed and runs here INSTEAD.
    #
    # The same PROXY-1/2/3 machines are reused across both scenarios.
    # To switch from OJP to pgBouncer (or vice-versa), stop the
    # current service on these nodes and start the other.
    # See ansible/README.md § "Switching between OJP and pgBouncer".
    # ─────────────────────────────────────────────────────────────
    proxy:
      hosts:
        proxy-1:
          ansible_host: <PROXY1_IP>
        proxy-2:
          ansible_host: <PROXY2_IP>
        proxy-3:
          ansible_host: <PROXY3_IP>

    # ─────────────────────────────────────────────────────────────
    # Load balancer — required for SUT-C (PgBouncer) only
    # HAProxy distributes connections across the three pgBouncer nodes.
    # Not needed for SUT-B (OJP): the OJP JDBC driver does client-side load balancing.
    # ─────────────────────────────────────────────────────────────
    lb:
      hosts:
        lb-node:
          ansible_host: <LB_IP>
          # ansible_user: ec2-user   # uncomment to override per host

    # ─────────────────────────────────────────────────────────────
    # Control node (your laptop) — always localhost
    # bench is built and run here; no SSH needed
    # ─────────────────────────────────────────────────────────────
    control:
      hosts:
        localhost:
          ansible_connection: local
