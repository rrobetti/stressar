---
# ansible/inventory.yml.example
#
# Copy this file to inventory.yml, fill in your actual IP addresses or hostnames,
# and optionally set per-host SSH user overrides.
#
# Usage:
#   cp ansible/inventory.yml.example ansible/inventory.yml
#   # edit ansible/inventory.yml
#   ansible-playbook -i ansible/inventory.yml ansible/playbooks/setup.yml

all:
  vars:
    # SSH user for all remote machines.
    # Override per host below if machines use different users.
    ansible_user: ubuntu

  children:

    # ─────────────────────────────────────────────────────────────
    # Database server — one host only
    # ─────────────────────────────────────────────────────────────
    db:
      hosts:
        db-node:
          ansible_host: <DB_IP>
          # ansible_user: ec2-user   # uncomment to override per host

    # ─────────────────────────────────────────────────────────────
    # Control host — orchestration only (no benchmark JVM execution)
    control:
      hosts:
        control-1:
          ansible_host: <CONTROL_IP>
          # If control is local on the same machine running Ansible, use:
          # ansible_host: 127.0.0.1
          # ansible_connection: local

    # Dedicated load-generator hosts — benchmark JVM replicas run here.
    loadgen:
      hosts:
        loadgen-1:
          ansible_host: <LOADGEN1_IP>
        loadgen-2:
          ansible_host: <LOADGEN2_IP>

    # OJP server tier (SUT-B)
    ojp:
      hosts:
        ojp-1:
          ansible_host: <OJP1_IP>
        ojp-2:
          ansible_host: <OJP2_IP>
        ojp-3:
          ansible_host: <OJP3_IP>

    # pgBouncer tier (SUT-C)
    pgbouncer:
      hosts:
        pgbouncer-1:
          ansible_host: <PGBOUNCER1_IP>
        pgbouncer-2:
          ansible_host: <PGBOUNCER2_IP>
        pgbouncer-3:
          ansible_host: <PGBOUNCER3_IP>

    # HAProxy tier (SUT-C)
    haproxy:
      hosts:
        haproxy-1:
          ansible_host: <HAPROXY_IP>

    # Optional compatibility groups when OJP and pgBouncer share the same nodes.
    # These child groups let existing commands still target "proxy"/"lb" names.
    # Safe to remove if not needed.
    proxy:
      children:
        ojp:
        pgbouncer:

    lb:
      children:
        haproxy:
