; {{ ansible_managed }}
; /etc/pgbouncer/pgbouncer.ini — managed by Ansible

[databases]
{{ db_name }} = host={{ hostvars[groups['db'][0]]['ansible_host'] }} port={{ db_port }} dbname={{ db_name }}

[pgbouncer]
listen_port               = {{ pgbouncer_port }}
listen_addr               = *
auth_type                 = md5
auth_file                 = {{ pgbouncer_userlist_file }}
pool_mode                 = {{ pgbouncer_pool_mode }}
default_pool_size         = {{ pgbouncer_pool_size }}
min_pool_size             = {{ pgbouncer_min_pool_size }}
max_client_conn           = {{ pgbouncer_max_client_conn }}
reserve_pool_size         = {{ pgbouncer_reserve_pool_size }}
reserve_pool_timeout      = {{ pgbouncer_reserve_pool_timeout }}
server_tls_sslmode        = disable
ignore_startup_parameters = extra_float_digits
; Unix socket used by the local metrics side-car (collect_pgbouncer_metrics.sh)
; to connect to the admin console without a password via peer authentication.
unix_socket_dir           = /tmp
; Allow the postgres OS user (which runs collect_pgbouncer_metrics.sh) to
; query the admin console for pool statistics during benchmark runs.
admin_users               = postgres
stats_users               = postgres
